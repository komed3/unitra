{
  "compilerOptions": {
    "target": "es2025",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": [ "node" ],
    "strict": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "composite": true,
    "skipLibCheck": true
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "extension": ".js"
  },
  "references": [
    { "path": "./packages/kernel/core" },
    { "path": "./packages/kernel/dict" },
    { "path": "./packages/kernel/dim" },
    { "path": "./packages/kernel/types" },
    { "path": "./packages/kernel/utils" },
    { "path": "./packages/plugin/prefix/si" },
    { "path": "./packages/plugin/quantity/base" },
    { "path": "./packages/plugin/unit/si/base" }
  ]
}
