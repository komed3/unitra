{
  "name": "unitra",
  "private": true,
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "type": "module",
  "scripts": {
    "build": "npm run tsc && npm run format",
    "build:clean": "npm run clean && npm run tsc && npm run format",
    "tsc": "pnpm -r build",
    "format": "prettier --ignore-path \"\" --write \"./packages/**/dist/**/*.@(js|d.ts)\" --log-level warn",
    "clean": "rimraf --glob \"**/dist\" && rimraf --glob \"**/tsconfig.tsbuildinfo\"",
    "lint": "pnpm -r lint",
    "test:linux": "for f in test/*.js; do node \"$f\"; done",
    "test:win32": "for %f in (test\\*.js) do node %f"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
