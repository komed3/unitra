{
  "name": "unitra",
  "private": true,
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "type": "module",
  "scripts": {
    "build": "npm run tsc && npm run format",
    "build:clean": "npm run clean && npm run tsc && npm run format",
    "tsc": "pnpm -r build",
    "format": "prettier --ignore-path \"\" --write \"./packages/**/dist/**/*.@(js|d.ts)\" --log-level warn",
    "clean": "rimraf --glob \"**/dist\" && rimraf --glob \"**/tsconfig.tsbuildinfo\"",
    "lint": "pnpm -r lint",
    "test:linux": "for f in test/*.js; do node \"$f\"; done",
    "test:win32": "for %f in (test\\*.js) do node %f",
    "script::version": "node scripts/version.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
