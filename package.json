{
  "name": "unitra",
  "private": true,
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "type": "module",
  "scripts": {
    "build": "npm run tsc && npm run format",
    "build:clean": "npm run clean && npm run tsc && npm run format",
    "tsc": "pnpm -r build",
    "format": "prettier --ignore-path \"\" --write \"./packages/**/dist/**/*.@(js|d.ts)\" --log-level warn",
    "clean": "rimraf --glob \"**/dist\" && rimraf --glob \"**/tsconfig.tsbuildinfo\"",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
